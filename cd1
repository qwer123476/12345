            fireproximityprompt(prompt)
            task.wait(0.25)

            -- 위치 복구
            hrp.CFrame = OCF

            -- 🔥 래그돌
            RagdollRemote:FireServer(hrp, 0.5)

            local successCheck = true

            while successCheck and AutoGucciT do
                if hum.Health <= 0 then
                    safeDestroy()
                    break
                end

                
                if seat and seat.Occupant ~= nil then
                    task.wait(0.5) 
                    safeDestroy()
                    break
                end

                -- 잡힘 / 래그돌 탈출
                if rag.Value == true or held.Value == true then
                    while (rag.Value == true or held.Value == true) and AutoGucciT do
                        rs.CharacterEvents.Struggle:FireServer()
                        task.wait()
                    end
                    break
                end

                local blobHRP = blobmanInstanceS:FindFirstChild("HumanoidRootPart")
                if blobHRP then
                    pcall(function()
                        SetNetworkOwner:FireServer(blobHRP, hrp)
                    end)

                    
                    
                    blobHRP.CFrame = blobHRP.CFrame + Vector3.new(0, 9999, 0)
                end

                task.wait()
            end

            
            OrionLib:MakeNotification({
                Name = "[ 🔓 ]",
