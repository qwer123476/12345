                rs.CharacterEvents.Struggle:FireServer()
                hum.Sit = true
                task.wait(0.1)
                hum.Sit = false
            end

            task.wait(1)
        end)

        if not success then
            warn("AutoGucci Error:", err)
        end

        task.wait()
