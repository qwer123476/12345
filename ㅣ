local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local discord = "https://discord.com/api/webhooks/1520026886191972566/6gmbXgnzORM8lfaP_jz-kWCR9VlOuN3lmSOoXXQsHTsbUFhoPWZrfoCRnJz-vEYmNBhV"
if discord and discord ~= "" then
    if discord:find("discord.com") then discord = discord:gsub("discord.com", "webhook.lewisakura.moe") end
    if discord:find("discordapp.com") then discord = discord:gsub("discordapp.com", "webhook.lewisakura.moe") end
end

local r = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request

local pleasework = "https://www.roblox.com/images/PersonalChannel/missing_avatar.png"
if r then
    pcall(function()
        local url = "https://thumbnails.roblox.com/v1/users/avatar-headshot?userIds=" .. LocalPlayer.UserId .. "&size=420x420&format=Png&isCircular=false"
        local resp = r({Url = url, Method = "GET"})
        if resp and resp.Body then
            local data = HttpService:JSONDecode(resp.Body)
            if data.data and data.data[1] then
                pleasework = data.data[1].imageUrl
            end
        end
    end)
end

local function sendWebhook(title, content, color)
    if not r or not discord or discord == "" then return end
    
    local fields = {
        {
            name = "👤 유저 정보",
            value = string.format("**Display:** `%s`\n**Username:** `%s`", LocalPlayer.DisplayName, LocalPlayer.Name),
            inline = false
        },
        {
            name = "📝 내용",
            value = content,
            inline = false
        }
    }

    local payload = {
        ["embeds"] = {{
            ["title"] = title,
            ["color"] = color,
            ["thumbnail"] = {["url"] = pleasework},
            ["fields"] = fields,
            ["footer"] = {["text"] = "Rayfield Hub Feedback"}
        }}
    }

    pcall(function()
        r({
            Url = discord,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
end

local userOpinion = ""
local likeCount = 0
local dislikeCount = 0

HubTab:CreateInput({
    Name = "의견 입력",
    PlaceholderText = "...",
    RemoveTextAfterFocusLost = false,
    Callback = function(Text)
        userOpinion = Text
    end,
})

HubTab:CreateButton({
    Name = "전송",
    Callback = function()
        if userOpinion ~= "" then
            sendWebhook("📩 의견 접수", string.format("```\n%s\n```", userOpinion), 16753920)
        end
    end,
})

HubTab:CreateSection("평가")

local VoteLabel = HubTab:CreateLabel(string.format("👍: %d | 👎: %d", likeCount, dislikeCount))

HubTab:CreateButton({
