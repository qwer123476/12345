--========================= POSTLUDE (slow-specific: display + GUI + boot) =========================
-- Response book ON for the slow (hint) bot: a rejected rare book word is
-- recoverable through the human 거부 button (in-class retry, then engine).
-- chair keeps it OFF — its auto-submit rejection path is unreviewed for the
-- book's single-word classes. RACE_BOOK_DISABLE (pre-loadstring) still wins.
RACE_BOOK_ON = true

state.onMyTurn = function()
    local letter = state.required_node or getStartingLetter(state.gd)
    if type(letter) ~= "string" or letter == "" then
        guiSet("word", "")
        guiSet("status", " no prompt")
        print("[race] my turn but NO PROMPT (required_node nil)")
        return
    end
    -- Double-fire memo: onLetterChanged AND CurrentTurnPlayer both call
    -- refreshTurn -> a full ~40-60ms pick used to run twice per turn on the
    -- identical position. Recompute only when anything decision-relevant
    -- moved (rejections bump counters so the reject re-pick always runs).
    local key = state.serial .. ":" .. state.movesThisRound .. ":" .. letter
        .. ":" .. tostring(RACE_REJECT_N)
    if key == RACE_LAST_PICK_KEY and RACE_SHOWN then
        return
    end
    RACE_LAST_PICK_KEY = key
    local t0 = os.clock()
    local w, note = racePick(letter)
    local ms = math.floor((os.clock() - t0) * 1000)
    if w then
        state.notePlanned(w)
        RACE_SHOWN = w
        guiSet("word", w)
        guiSet("status", " " .. tostring(note) .. " | 상대 " .. state.replyCount(w))
        print("[race] pick s=" .. state.serial .. " mv=" .. state.movesThisRound
            .. " '" .. letter .. "' -> " .. w .. " [" .. tostring(note)
            .. "] opp=" .. state.replyCount(w)
            .. " land=" .. canonKey(w:sub(-3)) .. " " .. ms .. "ms")
    else
        RACE_SHOWN = nil
        guiSet("word", "")
        guiSet("status", " no word: " .. tostring(letter))
        print("[race] NO WORD s=" .. state.serial .. " mv="
            .. state.movesThisRound .. " prompt='" .. tostring(letter)
            .. "' " .. ms .. "ms")
    end
end

state.onRejectHint = function()
    local rejected = RACE_SHOWN
    if rejected then
        state.ban(rejected)          -- round-scope (infra convention)
        RACE_DEAD[rejected] = true   -- match-scope (dict-miss or opp-used)
        RACE_SHOWN = nil
    end
    RACE_REJECT_N = RACE_REJECT_N + 1   -- invalidates the pick memo
    local dead = 0
    for _ in pairs(RACE_DEAD) do dead = dead + 1 end
    print("[race] REJECTED '" .. tostring(rejected) .. "' deadTotal=" .. dead
        .. " -> repick")
    state.onMyTurn()                 -- re-pick for the same prompt
end

--========================= 6. GUI (display shell + fallback button) =========================
GUI_STATUS = {}

function guiSet(key, val)
    if GUI_STATUS[key] then pcall(function() GUI_STATUS[key].Text = val end) end
end

-- Fallback button (channel 4: server rejected the shown word). Infra just relays
-- to the strategy's reject hook; the strategy owns which word was shown and how to
-- re-pick. No-op (with a note) when no strategy is plugged in.
function advanceHint()
    if state.onRejectHint then
        state.onRejectHint()
    else
        guiSet("status", " (no strategy plugged in)")
    end
end

