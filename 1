-- Re-execution guard: loadstring-ing this script twice used to leave the old
-- poll thread + game-over connection alive (double totalGames, wasted CPU).
-- A generation token retires the previous run's loops/connections.
RACEBOT_GEN = (RACEBOT_GEN or 0) + 1
local MY_GEN = RACEBOT_GEN
if RACEBOT_ROUNDEND_CONN then pcall(RACEBOT_ROUNDEND_CONN.Disconnect, RACEBOT_ROUNDEND_CONN) end

-- rRoundEnd = game over (reliable) → full reset + game counter.
do
    local Remotes = RS:WaitForChild("Remotes", 15)
    local rRoundEnd = Remotes and Remotes:FindFirstChild("PlayGameResultEffect")
    if rRoundEnd then
        RACEBOT_ROUNDEND_CONN = rRoundEnd.OnClientEvent:Connect(function()
            totalGames = totalGames + 1
            guiSet("streak", "G" .. totalGames)
            if state.gd then state.reset("round end (game over)") end
            guiSet("turn", " waiting")
        end)
    end
end

-- Table acquisition poll.
task.spawn(function()
    while RACEBOT_GEN == MY_GEN do
        local gd = findMyGameData()
        if gd and gd ~= state.gd then
            hookGameData(gd)
            guiSet("status", " connected")
        elseif not gd and state.gd then
            for _, c in ipairs(gdConns) do pcall(c.Disconnect, c) end
            gdConns = {}; state.gd = nil
            guiSet("turn", " waiting")
        end
        task.wait(1.5)
    end
end)

--========================= 8. Boot =========================
makeGUI()
do
    local boot = findMyGameData()
    if boot then hookGameData(boot) end
end
print("[bot] ready " .. MY)
print("[state] BUILD=slow-v2-race (observe-only; residual-relabel race strategy, counts="

    .. (RACE_TRUECOUNTS and "TRUE" or "approx") .. ")")
