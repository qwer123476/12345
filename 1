FunTab:AddButton({
    Name = "만들기",
    Callback = function()
        local ReplicatedStorage = game:GetService("ReplicatedStorage")
        local pencilCountText = PencilInput.Value -- Orion의 Textbox 값 호출 방식
        local TNUM = tonumber(pencilCountText)

        if not TNUM or TNUM <= 0 then  
            warn("Please enter a valid number!")  
            OrionLib:MakeNotification({
                Name = "[ ✏️ ]",
                Content = "유효한 숫자를 입력하세요.",
                Image = "rbxassetid://4483345998",
                Time = 3
            })
            return  
        end  

        local character = plr.Character or plr.CharacterAdded:Wait()  
        local hrp = character:WaitForChild("HumanoidRootPart")  
        local StickyPartEvent = ReplicatedStorage:WaitForChild("PlayerEvents"):WaitForChild("StickyPartEvent")  
        local SpawnToy = ReplicatedStorage:WaitForChild("MenuToys"):WaitForChild("SpawnToyRemoteFunction")

        -- 내부 함수 정의
        local function GetPlotNumber()
            local char = plr.Character
            if not char then return nil end
            if char.Parent == workspace then return nil end
            if char.Parent.Name == "PlayersInPlots" then
                for _, plot in workspace.Plots:GetChildren() do  
                    for _, owner in plot.PlotSign.ThisPlotsOwners:GetChildren() do  
                        if owner.Value == plr.Name then
                            return tonumber(string.match(plot.Name, "%d+"))
                        end
                    end
                end
            end
            return nil
        end

        local function GetInventory()
            local plotNumber = GetPlotNumber()
            if plotNumber then
                local plotItems = workspace:FindFirstChild("PlotItems")
                if plotItems and plotItems:FindFirstChild("Plot" .. plotNumber) then
                    return plotItems["Plot" .. plotNumber]
                end
            end
            return workspace:FindFirstChild(plr.Name .. "SpawnedInToys")
        end

        local function createPencil(index)
            while not plr.CanSpawnToy.Value do task.wait() end
            task.spawn(function()  
                SpawnToy:InvokeServer("ToolPencil", hrp.CFrame * CFrame.new(0,5,15), Vector3.new(0,0,0))  
            end)  
            task.wait(0.3)  
            local inv = GetInventory()  
            local pencil
            for _, item in pairs(inv:GetChildren()) do
                if item.Name == "ToolPencil" then pencil = item break end
            end
            if not pencil then return nil end  

            local stickyPart = pencil:WaitForChild("StickyPart")  
            local SoundPart = pencil:WaitForChild("SoundPart")  
            if stickyPart and SoundPart then  
                ReplicatedStorage.GrabEvents.SetNetworkOwner:FireServer(SoundPart, SoundPart.CFrame)  
                ReplicatedStorage.GrabEvents.SetNetworkOwner:FireServer(SoundPart, character.Torso.CFrame)  
            end  

            if SoundPart:FindFirstChild("PartOwner") then SoundPart.CFrame = CFrame.new(0, 599999, 999) end  
            stickyPart.Name = "w" .. index  
            for _, part in pairs(pencil:GetDescendants()) do  
                if part:IsA("BasePart") and part.Color == Color3.fromRGB(158, 108, 141) then part.Name = "a" .. index end  
            end  
            return pencil
        end

        -- 생성 및 연결 로직
        local pencils = {}
        for i = 1, TNUM do
            local p = createPencil(i)
            if p then table.insert(pencils, p) end
            task.wait(0.1)
        end

        for i = 1, #pencils - 1 do
            local cur, nxt = pencils[i], pencils[i + 1]
            if cur and nxt then  
                local aF = cur:FindFirstChild("w" .. i)  
                local aT = nxt:FindFirstChild("a" .. (i + 1))  
                if aF and aT then StickyPartEvent:FireServer(aF, aT, CFrame.Angles(0, math.rad(-90), 0)) end  
            end  
            task.wait(0.05)
        end

        local torso2 = character:WaitForChild("HumanoidRootPart"):WaitForChild("RagdollTouchedHitbox")
        if torso2 and #pencils >= TNUM then
            local lastP = pencils[TNUM]
            local wLast = lastP:FindFirstChild("w" .. TNUM)
            if wLast then
                local relCF = torso2.CFrame:ToObjectSpace(torso2.CFrame * CFrame.new(0, -1.1, 0.1) * CFrame.Angles(0, math.rad(180), 0))
                StickyPartEvent:FireServer(wLast, torso2, relCF)
            end
        end
    end
})




