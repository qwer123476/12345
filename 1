-- kt_engine.lua — kt-specific SHELL around the racebot strategy module.
--
-- ARCHITECTURE (2026-07-06 rewrite): the strategy is now `racebot.lua` (verbatim
-- from kkutu_research, the residual-relabel race engine measured 433:5 vs the old
-- policy). build_bots.py assembles the ENGINE region as:
--     RaceBot = (function()  <racebot.lua>  end)()      -- the strategy module
--     <THIS FILE>                                       -- the kt shell
-- so racebot.lua stays byte-verbatim (re-syncable from research) and this shell
-- holds everything kt-specific: config, payload load, the external-drive
-- extensions, the `state` lifecycle machine, and Roblox observation wiring.
--
-- WHY external-drive: racebot's native interface (myTurn/accepted/rejected) infers
-- the opponent's moves. The kt bots instead OBSERVE every real transition
-- (StartingLetter changes) and drive racebot's consumption directly — strictly
-- more accurate (we see the opponent's actual (start,end) class). So we bypass
-- myTurn/accepted/rejected and use consumePair/pickFor/noteDead (defined below).
--
-- All top-level names are GLOBAL on purpose: the main chunk is register-sensitive
-- (Luau caps a function at 200 local slots), so keeping top-level locals near zero
-- leaves headroom for the per-bot adapters. racebot's own locals live nested in
-- its IIFE and don't count against the main chunk.

--========================= 0. Executor env + config =========================
HS = game:GetService("HttpService")
RS = game:GetService("ReplicatedStorage")
LP = game.Players.LocalPlayer
MY = LP.Name

-- Data gist: change ONLY this base when re-uploading to a fresh gist (the cache
-- tag mixes in a hash of the base so a base change auto-invalidates every cache).
DATA_GIST_BASE = "https://gist.githubusercontent.com/GUMI2029/fecbfae5a7d44423a882002df65de3d2/raw"
RACEBOT_DATA_URL = DATA_GIST_BASE .. "/racebot_data.json"
DATA_CACHE_VERSION = "20260708_openerpools"  -- bump: racebot_data.json gained opener_pools + opener_traps
-- (cache tag is URL-hash based, NOT content-based — a data change with no version bump
--  leaves warm clients on stale cache, so every payload-shape change MUST bump this.)
CACHE_TAG = nil
do
    local h = 5381
    for i = 1, #DATA_GIST_BASE do
        h = (h * 33 + DATA_GIST_BASE:byte(i)) % 16777213
    end
    CACHE_TAG = DATA_CACHE_VERSION .. "_" .. tostring(h)
end
RACEBOT_DATA_CACHE = "kkutu_racebot_data_" .. CACHE_TAG .. ".json"

-- Bot alt-account names are injected by the caller (BOT_ACCOUNT_NAMES global)
-- BEFORE loadstring — never hardcoded in this public Gist.
BOT_ACCOUNTS = {}
if type(BOT_ACCOUNT_NAMES) == "table" then
    for _, name in ipairs(BOT_ACCOUNT_NAMES) do
        if type(name) == "string" and name ~= "" then BOT_ACCOUNTS[name] = true end
    end
end

-- LIVE-LEARNED opener-banned LANDINGS (raw syllables). racebot's static_loss is
-- computed from the kkeugeul dictionary, which OVER-counts live playability: a
-- landing may show replies in our data but be a dead-end LIVE (ggeugle ⊋ live
-- dict — see [[kt-ggeugle-not-live-dict]]), so the live server rejects opening
-- onto it as a 필승 opener. Those can only be found by in-game testing. This is
-- the extendable list of such landings — a round OPENER may not END on any of
-- them. Dueum-merged at load (banning 룻 also bans its 두음 twin 눗, same node).
-- 룻: user-confirmed 2026-07-06 (나룻 opener bounced live though kkeugeul shows 6).
-- 밈/욹/낀/값/욤/츰/슨: user-confirmed 2026-07-07 (opener may not END on these — the
--   restriction is per-syllable and looks arbitrary, so it is auto-learned, below).
-- 늬: user-confirmed 2026-07-07 (node 395, no dueum twin — opener may not END on 늬).
OPENER_DEAD_LANDINGS = {
    ["룻"] = true, ["밈"] = true, ["욹"] = true, ["낀"] = true,
    ["값"] = true, ["욤"] = true, ["츰"] = true, ["슨"] = true,
    ["늬"] = true,
}
OPENER_BANS_FILE = "kkutu_opener_bans.txt"   -- persisted auto-learned landings

-- Merge persisted auto-learned opener-dead landings (one raw syllable per line).
-- Called at payload load BEFORE resolving OPENER_DEAD_LANDING_NODES.
function loadOpenerBans()
    if type(readfile) ~= "function" then return end
    local has = (type(isfile) ~= "function") or (pcall(isfile, OPENER_BANS_FILE) and isfile(OPENER_BANS_FILE))
    if not has then return end
    local ok, body = pcall(readfile, OPENER_BANS_FILE)
    if ok and type(body) == "string" then
        for syl in body:gmatch("[^\r\n]+") do
            if #syl >= 3 then OPENER_DEAD_LANDINGS[syl:sub(-3)] = true end
        end
    end
end

-- Learn + persist a new opener-dead landing: the server rejected a ROUND opener that
-- ENDS on `syl`. 1-strike — the bot's openers are proven winners, so a live reject is
-- strong evidence the LANDING syllable is server-banned (not the single word); the
-- re-pick falls back to another winning opener on a legal landing, and every future
-- opener that would land here is skipped. Idempotent; persists across sessions.
function learnOpenerDeadLanding(syl)
    if type(syl) ~= "string" or #syl < 3 then return end
    syl = syl:sub(-3)
    if OPENER_DEAD_LANDINGS[syl] then return end
    OPENER_DEAD_LANDINGS[syl] = true
    if RACE and RACE.data and RACE.data.syl2node then
        local id = RACE.data.syl2node[syl]
        if id then
            OPENER_DEAD_LANDING_NODES = OPENER_DEAD_LANDING_NODES or {}
            OPENER_DEAD_LANDING_NODES[id] = true
        end
    end
    if type(appendfile) == "function" then
        pcall(appendfile, OPENER_BANS_FILE, syl .. "\n")
    elseif type(writefile) == "function" then
        local body = ""
        if type(readfile) == "function" and (type(isfile) ~= "function" or isfile(OPENER_BANS_FILE)) then
            local ok, b = pcall(readfile, OPENER_BANS_FILE); if ok and type(b) == "string" then body = b end
        end
        pcall(writefile, OPENER_BANS_FILE, body .. syl .. "\n")
    end
    print("[race] learned opener-dead landing (server-banned ending): " .. syl)
end

-- MID-GAME KILL-LEARNING (ddaggi root cause #1). The prepared expert funnels the
-- bot to a dead-end syllable via a LIVE word our dict lacks (레>쿄 etc.) — a
-- dict-gap 한방 our engine can't see. When the bot is stuck mid-chain at a
-- STRUCTURALLY-dead required syllable, the node P it last landed the opponent on
-- (RACE.myLanding) has such a kill edge; learn P as a kill-source so we avoid
-- landing the opponent there vs this prepared opponent. Mirror of the opener
-- learner (raw-strike, persisted, sessions). KILL_LEARNING=false = kill-switch.
KILL_LEARNING = true
-- Version-tagged (fix 2026-07-08): node ids are payload-version-specific, so a data
-- rebuild MUST invalidate the persisted file — else stale ids point at renumbered,
-- innocent nodes and the bot avoids good landings. Mirrors RACEBOT_DATA_CACHE's tag.
-- (DATA_CACHE_VERSION is defined near the top of this shell, above.)
KILL_SOURCES_FILE = "kkutu_kill_sources_" .. DATA_CACHE_VERSION .. ".txt"

-- Load persisted kill-source NODES (+ any payload seed) into RACE.killSrc. Node ids
-- are payload-version-specific; a dict rebuild invalidates the file, but each source
-- is cheap to re-learn (one death). Called at payload load after RaceBot.new.
function loadKillSources()
    if not (RACE and RACE.killSrc) then return end
    if RACE.data and RACE.data.seed_kill_sources then
        for _, p in ipairs(RACE.data.seed_kill_sources) do RACE.killSrc[p] = true end
    end
    if type(readfile) ~= "function" then return end
    local has = (type(isfile) ~= "function") or (pcall(isfile, KILL_SOURCES_FILE) and isfile(KILL_SOURCES_FILE))
    if not has then return end
    local ok, body = pcall(readfile, KILL_SOURCES_FILE)
    if ok and type(body) == "string" then
        for line in body:gmatch("[^\r\n]+") do
            local id = tonumber(line)
            if id then RACE.killSrc[id] = true end
        end
    end
end

function persistKillSource(p)
    if type(appendfile) == "function" then
        pcall(appendfile, KILL_SOURCES_FILE, tostring(p) .. "\n")
    elseif type(writefile) == "function" then
        local body = ""
        if type(readfile) == "function" and (type(isfile) ~= "function" or isfile(KILL_SOURCES_FILE)) then
            local ok, b = pcall(readfile, KILL_SOURCES_FILE); if ok and type(b) == "string" then body = b end
        end
        pcall(writefile, KILL_SOURCES_FILE, body .. tostring(p) .. "\n")
    end
end

-- Bot stuck mid-chain at required=Q (racePick returned nil). Learn only if the
-- structural-dead guard holds (Q has NO classes in our graph = a hard fact, not a
-- transient depletion the residual relabel already models) and we actually landed
-- the opponent this round. Escalates the seat to hostile (a dict-gap kill = a
-- prepared opponent) and records P=myLanding. 1-strike, idempotent, persisted.
function maybeLearnMidKill(Q)
    if not (KILL_LEARNING and RACE and RACE.learnKills) then return end
    if not RACE.myLanding then return end
    if not (state and state.movesThisRound and state.movesThisRound >= 1) then return end
    local qnode = RACE.data.syl2node and RACE.data.syl2node[Q]
    local structurallyDead = (qnode == nil) or (#(RACE.outC[qnode] or {}) == 0)
    if not structurallyDead then return end          -- depletion death, not dict-gap
    local p = RACE.myLanding
    if RACE.setHostile then RACE:setHostile() end
    if not RACE.killSrc[p] then
        RACE:learnKill(p)
        persistKillSource(p)
        print("[race] learned mid-kill source node=" .. tostring(p)
            .. " (stuck at dead " .. tostring(Q) .. ")")
    end
end

--========================= 1. racebot external-drive extensions =========================
-- racebot.lua (embedded above by build_bots) defines the global `RaceBot`. These
-- kt-only methods let us drive it from observed transitions instead of self-play.
-- REFINED (racebot-v2): (fromPos,toPos) no longer identifies a UNIQUE class.
-- Under 두음 splits a landing position toPos may be reached from fromPos by
-- several classes (distinct acceptor profiles A(f) sharing a source + landing).
-- Mirror racebot.lua `_inferOppTransition`: among the classes landing on toPos,
-- consume the MAX-live one whose avail contains fromPos. Sum-exact per
-- transition (only the consumed COUNT changes the live total); WHICH acceptor
-- class is the same documented ~≤1/transition partial-observation approximation
-- the offline engine uses. On dueum=False (singleton avail) this is unique.
function RaceBot:cidOf(fromSyl, toSyl)
    local f = self.data.syl2node[fromSyl]
    local t = self.data.syl2node[toSyl]
    if not f or not t then return nil end
    local bigCid, bigK = nil, 0
    for _, cid in ipairs(self.inC[t]) do
        if self.live[cid] > bigK then
            local hit = false
            for _, p in ipairs(self.data.avail[cid]) do
                if p == f then hit = true; break end
            end
            if hit then bigCid, bigK = cid, self.live[cid] end
        end
    end
    return bigCid
end

-- Consume the observed transition fromSyl->toSyl (one word of that class was
-- played, whoever played it). A transition absent from our dict = nothing to
-- track (returns false). Over-consumption is clamped inside RaceBot:_consume
-- (counted as negClamped) — same self-heal direction as the old state.play clamp.
function RaceBot:consumePair(fromSyl, toSyl)
    local cid = self:cidOf(fromSyl, toSyl)
    if cid then self:_consume(cid); return true end
    return false
end

-- Does ANY class exist for fromSyl->toSyl, ignoring live counts? Distinguishes a
-- genuine dict-gap (no class at all = a live-only word we don't have) from mere
-- DEPLETION (classes exist but all spent). consumePair==false conflates the two;
-- the hostile-escalation must fire only on the former (see state.play).
function RaceBot:pairExists(fromSyl, toSyl)
    local f = self.data.syl2node[fromSyl]
    local t = self.data.syl2node[toSyl]
    if not f or not t then return false end     -- syllable not in our graph = genuine gap
    for _, cid in ipairs(self.inC[t]) do
        for _, p in ipairs(self.data.avail[cid]) do
            if p == f then return true end       -- some class covers it (live or spent)
        end
    end
    return false
end

function RaceBot:remainingPair(fromSyl, toSyl)
    local cid = self:cidOf(fromSyl, toSyl)
    return (cid and self.live[cid]) or 0
end

-- Words still playable FROM syl = the opponent's escape count after landing
-- there (0 => 한방). Used for the hint's status readout.
function RaceBot:totalFrom(syl)
    local u = self.data.syl2node[syl]
    return (u and self.total[u]) or 0
end

-- Pick for a required syllable (nil/"" = free open). Builds the tiered queue from
-- the CURRENT live counts (externally driven) and returns the first fresh word +
-- its tier note. Mirrors racebot:myTurn WITHOUT the built-in opponent inference
-- (kt already consumed the opponent's move via observation).
function RaceBot:pickFor(requiredSyl)
    self.pending = nil
    if requiredSyl ~= nil and requiredSyl ~= "" then
        local v = self.data.syl2node[requiredSyl]
        if v then
            self.queue, self.queueNote, self.queueCid = self:_buildChainQueue(v)
        else
            self.queue, self.queueNote, self.queueCid = {}, {}, {}  -- nothing to play
        end
    else
        self.queue, self.queueNote, self.queueCid = self:_buildOpenQueue()
    end
    self.qi = 0
    local w = self:_next()
    return w, self.note
end

-- Mark an exact word match-dead (server rejected it, or opponent already used
-- it): never re-offered until reset(). Source of truth for the reject path.
function RaceBot:noteDead(word)
    if type(word) == "string" and word ~= "" then
        self.dead[word] = true
        self.counters.rejects = self.counters.rejects + 1
    end
end

-- Mark an exact word as ours-used so it's never re-offered (matches the old
-- state.suggested — retire a hint once we have positive evidence it was played).
function RaceBot:noteUsed(word)
    if type(word) == "string" and word ~= "" then self.used[word] = true end
end

-- OPENER BAN (2026-07-06 fix). racebot.lua is the race POLICY only: mid-chain it
-- PREFERS 한방 (buildChainQueue's first tier) — correct mid-chain, but ILLEGAL as
-- a round opener. Offline the arena referee injects openers ("policies never
-- open") and racesolver delegates free-opens to the classic solver, so racebot
-- never applied the opener ban itself. Live, the opener is letter-constrained and
-- routes through the race tiering, so the bot tried 한방/유도 openers every round.
-- This mirrors arena.referee._opener_ban_violation EXACTLY, on our own data: a
-- round's first word is banned iff its landing strands the opponent instantly
-- (한방, on DEPLETED counts) OR lands on a STATIC-LOSS node (필승/유도).
function RaceBot:openerBanned(word)
    if type(word) ~= "string" or #word < 3 then return false end
    local target = self.data.syl2node[word:sub(-3)]
    if not target then return false end   -- unknown landing: can't judge -> allow
    -- REFINED self-loop: mirror _buildChainQueue's opp adjustment (a class is a
    -- self-loop iff its PRIMARY source == landing = avail[cid][1]==target), not
    -- the canonical start-node==target test. cidOf picks the observed class.
    local cid = self:cidOf(word:sub(1, 3), word:sub(-3))
    local selfloop = (cid and self.data.avail[cid][1] == target) and 1 or 0
    local opp = self.total[target] - selfloop
    if opp <= 0 then return true end                 -- 한방 opener
    if self.staticLoss[target] then return true end  -- 필승(유도) opener
    -- exact self-loop-parity TRAP: static-UNKNOWN landing the exact engine proves
    -- is a MOVER-win, so landing the opponent there is a proven LOSS for us (the
    -- 기윽 -> opp 윽윽 self-loop parity bug — 윽 shows opp=6 > 0 and is not
    -- static-LOSS, so it slipped past the checks above). Vetoing it here makes the
    -- pool-exhausted fallback path (_next / _buildChainQueue) trap-safe too.
    if self.openerTraps and self.openerTraps[target] then return true end
    -- live-learned dead landings (kkeugeul over-counts; server rejects live)
    if OPENER_DEAD_LANDING_NODES and OPENER_DEAD_LANDING_NODES[target] then
        return true
    end
    return false
end

-- Pick for a ROUND OPENER (movesThisRound == 0). Builds the same tiered queue as
-- pickFor, but skips any candidate that violates the opener ban (한방/static-유도/
-- seed/live-learned EXPLICIT landing set). The ban is a specific per-syllable set,
-- NOT a low-escape rule — most low-escape openers are live-legal (user-confirmed
-- 2026-07-07), so we do NOT filter by escape count. Falls back to the full queue
-- only if NO legal opener exists (rare; best-effort).
function RaceBot:pickForOpener(requiredSyl)
    self.pending = nil
    -- PRECOMPUTED POOL FIRST (first-player opener fix). For the given start
    -- syllable, self.openerPools[node] is an offline-vetted, exact-safe opener list
    -- (proven win first, neutral fallback; trap/유도/한방 landings already removed).
    -- This is the primary opener source — it is where "reasonable opening" is
    -- guaranteed. We still re-check openerBanned per word (server may have banned a
    -- landing since the pool was built; the runtime learns those) and skip
    -- used/dead. Falls through to the tiered queue only if the pool is empty/spent.
    local poolNode = nil
    if requiredSyl ~= nil and requiredSyl ~= "" then
        poolNode = self.data.syl2node[requiredSyl]
    end
    if poolNode and self.openerPools and self.openerPools[poolNode] then
        for _, w in ipairs(self.openerPools[poolNode]) do
            if not self.used[w] and not self.dead[w] and not self:openerBanned(w) then
                self.pending = w
                self.pendingCid = self:cidOf(w:sub(1, 3), w:sub(-3))
                self.note = "opener-pool"
                return w, self.note
            end
        end
    end
    if requiredSyl ~= nil and requiredSyl ~= "" then
        local v = self.data.syl2node[requiredSyl]
        if v then
            self.queue, self.queueNote, self.queueCid = self:_buildChainQueue(v)
        else
            self.queue, self.queueNote, self.queueCid = {}, {}, {}
        end
    else
        self.queue, self.queueNote, self.queueCid = self:_buildOpenQueue()
    end
    self.qi = 0
    local q = self.queue
    while self.qi < #q do
        self.qi = self.qi + 1
        local w = q[self.qi]
        if not self.used[w] and not self.dead[w] and not self:openerBanned(w) then
            self.pending = w
            self.pendingCid = self.queueCid[self.qi]
            self.note = self.queueNote[self.qi]
            return w, self.note
        end
    end
    -- no legal opener from this prompt — fall back to the best available
    -- (live may still reject; the reject path then walks on + auto-learns).
    self.qi = 0
    local w = self:_next()
    return w, self.note
end

--========================= 2. Data load + node identity =========================
NODE_SYL = {}     -- node id -> a canonical representative syllable (dueum-merged)
RACE = nil        -- the RaceBot instance (nil until the payload loads)

function loadJSON(url, cacheFile)
    if isfile and isfile(cacheFile) then
        local ok, r = pcall(function() return HS:JSONDecode(readfile(cacheFile)) end)
        if ok and type(r) == "table" then return r end
    end
    local ok, body = pcall(function() return game:HttpGet(url) end)
    if ok and body and #body > 10 then
        local ok2, r = pcall(HS.JSONDecode, HS, body)
        if ok2 and type(r) == "table" then
            if writefile then pcall(writefile, cacheFile, body) end
            return r
        end
    end
    return nil
end

do
    local data = loadJSON(RACEBOT_DATA_URL, RACEBOT_DATA_CACHE)
    if type(data) == "table" and type(data.meta) == "table" then
        local ok, inst = pcall(RaceBot.new, data)
        if ok and inst then
            RACE = inst
            for syl, id in pairs(data.syl2node) do
                if not NODE_SYL[id] then NODE_SYL[id] = syl end
            end
            -- Merge persisted auto-learned bans, then resolve opener-dead landings to
            -- node ids (dueum-merged: 룻 and 눗 share a node, so banning one bans both).
            loadOpenerBans()
            OPENER_DEAD_LANDING_NODES = {}
            for syl in pairs(OPENER_DEAD_LANDINGS) do
                local id = data.syl2node[syl]
                if id then OPENER_DEAD_LANDING_NODES[id] = true end
            end
            -- Mid-game kill-learning: apply the kill-switch to the racebot flag, then
            -- seed killSrc from the payload + persisted learned sources.
            RACE.learnKills = RACE.learnKills and (KILL_LEARNING ~= false)
            loadKillSources()
            -- REFINED (racebot-v2) schema sanity: multi-source `avail` replaces
            -- pairCid/class_from. Fail loud if a CANONICAL payload slips in — it
            -- would silently mis-drive the refined shell (phantom picks return).
            assert(type(data.avail) == "table" and type(data.avail[1]) == "table",
                "racebot_data not refined (no avail[]) — rebuild via export_racebot")
            print("[race] payload ok: model=" .. tostring(data.meta.model)
                .. " nodes=" .. tostring(data.meta.n_nodes)
                .. " classes=" .. tostring(data.meta.n_classes)
                .. " dueum=" .. tostring(data.meta.dueum)
                .. " fp=" .. tostring(data.meta.fingerprint))
        else
            print("[race] FATAL RaceBot.new failed: " .. tostring(inst))
        end
    else
        print("[race] FATAL racebot_data load failed (no data / bad payload)")
    end
end

-- Canonical syllable for a raw syllable (dueum-aware via the node it maps to);
-- identity for syllables absent from the graph. Used by the hint retire-guard
-- and by the adapters for display/telemetry.
function canonKey(s)
    if type(s) ~= "string" or s == "" then return s end
    if not RACE then return s end
    local id = RACE.data.syl2node[s]
    return (id and NODE_SYL[id]) or s
end

--========================= 3. GameData read primitives (observe-only) =========================
function getValueOrAttribute(owner, name)
    if not owner then return nil end
    local child = owner:FindFirstChild(name)
    if child then
        local ok, value = pcall(function() return child.Value end)
        if ok and value ~= nil then return value end
    end
    local ok, value = pcall(function() return owner:GetAttribute(name) end)
    if ok then return value end
    return nil
end

function getCurrentTurnPlayer(gd)
    return getValueOrAttribute(gd, "CurrentTurnPlayer")
end

function getStartingLetter(gd)
    local value = getValueOrAttribute(gd, "StartingLetter")
    if type(value) == "string" and value ~= "" then return value end
    return nil
end

function playerNameFromValue(value)
    if typeof(value) == "Instance" and value:IsA("Player") then return value.Name end
    if type(value) == "string" and value ~= "" then return value end
    return nil
end

function isLocalPlayerValue(value)
    if value == LP then return true end
    if typeof(value) == "Instance" and value:IsA("Player") then return value == LP end
    return type(value) == "string" and value == MY
end

function getOpponentNames(gd)
    local names = {}
    local pl = gd and gd:FindFirstChild("Players")
    if not pl then return names end
    for _, v in ipairs(pl:GetChildren()) do
        if v:IsA("ObjectValue") and v.Value and v.Value ~= LP then
            table.insert(names, v.Value.Name)
        end
    end
    return names
end

function hasOpponentBot(gd)
    for _, name in ipairs(getOpponentNames(gd)) do
        if BOT_ACCOUNTS[name] then return true end
    end
    return false
end

function lifeKeyForPlayerValue(v)
    if not v or not v:IsA("ObjectValue") then return nil end
    local value = v.Value
    if typeof(value) == "Instance" and value:IsA("Player") then return value.Name end
    return v.Name
end

function readLifeCount(v)
    if not v or not v:IsA("ObjectValue") then return nil end
    local ok, lives = pcall(function() return v:GetAttribute("Lives") end)
    if ok and type(lives) == "number" then return lives end
    return nil
end

--========================= 4. state — lifecycle machine (RACE-backed) =========================
-- The lifecycle skeleton is UNCHANGED from the old edge-capacity engine (this is
-- the battle-tested observation contract). Only the DATA BACKING moved: instead
-- of state.consumed[a][b], consumption now lives in the racebot instance (RACE),
-- driven by state.play/checkSelfLoopHandoff via RaceBot:consumePair.
-- Fed by four channels: (1) word played -> state.play [StartingLetter change],
-- (2) round/match break -> state.round/reset [life-loss / rRoundEnd / table],
-- (3) who opens -> movesThisRound==0 on my turn, (4) rejection -> state.ban.
state = {
    gd = nil,
    required_node = nil,     -- raw StartingLetter the next word must start from
    movesThisRound = 0,      -- words played this chain; 0 on my turn => I open (선공)
    firstMove = true,
    serial = 0,
    banned = {},             -- exact words rejected/blocked this round (round-scope)
    suggested = {},          -- kept for adapter compat; racebot.used is the real dedup
    lifeCounts = {},
    lastEdge = nil,          -- last observed {fromSyl, toSyl} (B1 telemetry)
    pendingOwnWord = nil,    -- word the strategy plans to play (retired to used ONLY if actually played)
    pendingOwnLanding = nil, -- canonKey of that word's landing — retire-guard (see state.play)
    lastTurnOwner = nil,     -- for genuine turn-handoff detection (self-loop inference)
    turnOpen = false,
    movesAtHandoff = 0,
    awaitingOpener = true,   -- boundary guard: next letter change = prompt, not a play
    pendingRound = false,    -- set SYNCHRONOUSLY on a life drop, cleared in round()
    selfLoopPending = false,
    matchRound1 = true,
    onMyTurn = nil,          -- adapter assigns: pick a word + act
    onRejectHint = nil,      -- adapter assigns: server rejected the shown word
}

function state.isMyTurn()
    if not state.gd then return false end
    return isLocalPlayerValue(getCurrentTurnPlayer(state.gd))
end

-- opponent's escapes after we play `word` (status readout only). 0 => 한방.
function state.replyCount(word)
    if type(word) ~= "string" or #word < 3 or not RACE then return 0 end
    return RACE:totalFrom(word:sub(-3))
end

function state.resetBanned()
    state.banned = {}
end

function state.snapshotLives()
    local m = {}
    local pl = state.gd and state.gd:FindFirstChild("Players")
    if pl then
        for _, v in ipairs(pl:GetChildren()) do
            local k = lifeKeyForPlayerValue(v)
            local l = readLifeCount(v)
            if k and l then m[k] = l end
        end
    end
    return m
end

-- Server rejected `word` (or opponent already used it): match-dead in racebot so
-- it is never re-offered, plus round-scope banned for adapter bookkeeping.
function state.ban(word)
    if type(word) == "string" and word ~= "" then
        state.banned[word] = true
        if RACE then RACE:noteDead(word) end
        -- ROUND-opener rejection (movesThisRound==0 on my turn = I opened, 선공):
        -- the ENDING syllable is likely a server-banned opener landing. Learn +
        -- persist it so the re-pick skips ALL openers landing there (no churn).
        if state.movesThisRound == 0 and #word >= 3 then
            learnOpenerDeadLanding(word:sub(-3))
        end
    end
end

function state.markSuggested(word)
    if type(word) == "string" and word ~= "" then
        state.suggested[word] = true
        if RACE then RACE:noteUsed(word) end
    end
end

-- Strategy calls this with the word it plans to play. On the next turn-advance
-- (state.play) it is retired into racebot.used ONLY if the observed landing
-- matches (positive evidence it was actually played) — see the retire-guard.
function state.notePlanned(word)
    if type(word) == "string" and word ~= "" then
        state.pendingOwnWord = word
        state.pendingOwnLanding = canonKey(word:sub(-3))
    end
end

-- Lifecycle telemetry: racebot counters (cheap; avoids scanning 147k classes).
function state.poolStats()
    if not RACE then return 0, 0, 0 end
    local dead = 0
    for _ in pairs(RACE.dead) do dead = dead + 1 end
    return RACE.counters.relabels or 0, RACE.counters.negClamped or 0, dead
end

-- Channel 1: a word landed on `node`. Consume the observed edge (required_node ->
-- node) in racebot, advance the chain, and (if the landing matches our shown
-- hint) retire the hint into racebot.used.
function state.play(node)
    if type(node) ~= "string" or node == "" then return end
    local prev = state.required_node
    if prev then
        if RACE then
            local ok = RACE:consumePair(prev, node)     -- over-consume clamped inside _consume
            -- consumePair false = the transition prev->node matches NO class in our
            -- dict = a live word outside our dict (the CLAMPED-proof of a dict-gap).
            -- One such observed this match => the opponent wields live-only words =>
            -- escalate to hostile so kill-source avoidance activates for the match.
            -- consumePair==false means cidOf found no LIVE class for prev->node — but
            -- that ALSO happens when the pair's classes are merely DEPLETED (in-dict, a
            -- normal opponent late in a long chain), NOT only on a real dict-gap. Gating
            -- on pairExists prevents a false hostile escalation (which would wrongly make
            -- the bot avoid seeded kill-sources vs an ordinary opponent).
            if ok == false and KILL_LEARNING and RACE.setHostile and not RACE.hostile
               and not RACE:pairExists(prev, node) then
                RACE:setHostile()
                print("[race] hostile seat: dict-gap live word observed (" .. tostring(prev)
                    .. ">" .. node .. ") — kill-source avoidance ON")
            end
        end
        state.lastEdge = {prev, node}
    end
    state.required_node = node
    state.movesThisRound = state.movesThisRound + 1
    state.firstMove = false
    if state.pendingOwnWord then
        -- BUG-FIX carry-over (2026-07-05): only retire our hint when the played
        -- LANDING matches — positive evidence it was actually played. A different
        -- landing (human deviated / opponent's move) must NOT lock the hint, or
        -- it silently drops from all future suggestions ("논리 끊어짐").
        if canonKey(node) == state.pendingOwnLanding then
            if RACE then
                RACE:noteUsed(state.pendingOwnWord)
                -- P = the node OUR word just landed the opponent on. The mid-game
                -- kill-learner reads RACE.myLanding, which racebot sets in accepted() —
                -- a path this external-drive shell NEVER takes, so without this line
                -- myLanding stays nil forever and kill-LEARNING is dead code. Reset per
                -- round in state.round so it means "landed the opponent THIS round".
                RACE.myLanding = RACE.data.syl2node[node]
            end
            state.suggested[state.pendingOwnWord] = true
        end
        state.pendingOwnWord = nil
        state.pendingOwnLanding = nil
    end
    print("[state] play " .. tostring(prev) .. ">" .. node
        .. " moves=" .. state.movesThisRound .. " serial=" .. state.serial)
end

-- Channel 2a: new chain, KEEP the racebot pool (a life was lost, same match).
-- Used words persist across rounds (live rule), so RACE is NOT reset here.
function state.round(reason)
    state.required_node = getStartingLetter(state.gd)
    state.movesThisRound = 0
    state.firstMove = true
    state.pendingOwnWord = nil
    state.pendingOwnLanding = nil
    state.turnOpen = false
    state.movesAtHandoff = 0
    state.pendingRound = false
    state.matchRound1 = false
    -- kill-learning: a new round means we have NOT landed the opponent yet — clear P so
    -- maybeLearnMidKill can't attribute this round's death to a previous round's landing.
    -- (state.reset already nils it via RACE:reset(); state.round is keep-pool and doesn't.)
    if RACE then RACE.myLanding = nil end
    -- The NEW round's prompt often replicates AFTER this handler runs, so the
    -- FIRST letter change after a boundary is the prompt, not a play — arm the
    -- capture so it isn't consumed as a phantom edge (review finding 2026-07-04).
    state.awaitingOpener = true
    state.resetBanned()
    state.lifeCounts = state.snapshotLives()
    state.serial = state.serial + 1
    local rl, nc, dead = state.poolStats()
    print("[state] round KEEP-POOL: " .. tostring(reason)
        .. " node=" .. tostring(state.required_node) .. " serial=" .. state.serial
        .. " | relabels=" .. rl .. " clamps=" .. nc .. " dead=" .. dead)
end

-- Channel 2b: full match reset, CLEAR the racebot pool (rebuild live/total).
function state.reset(reason)
    if RACE then RACE:reset() end
    state.required_node = getStartingLetter(state.gd)
    state.movesThisRound = 0
    state.firstMove = true
    state.suggested = {}
    state.pendingOwnWord = nil
    state.pendingOwnLanding = nil
    state.turnOpen = false
    state.movesAtHandoff = 0
    state.pendingRound = false
    state.matchRound1 = true
    state.awaitingOpener = true
    state.lastTurnOwner = nil    -- a stale owner would suppress the first handoff of a rematch
    state.resetBanned()
    state.lifeCounts = state.snapshotLives()
    state.serial = state.serial + 1
    print("[state] RESET (clear pool): " .. tostring(reason)
        .. " node=" .. tostring(state.required_node) .. " serial=" .. state.serial)
end

-- Channel 3: predicate — is this MY opening move of the chain?
function state.open_round()
    return state.isMyTurn() and state.movesThisRound == 0
end

--========================= 5. Strategy bridge =========================
-- racePick(letter): the single entry the adapters call to get a move. letter is
-- the current prompt (the game assigns one even for round openers, so this is a
-- letter-constrained pick via racebot's chain tiers). nil/"" => free open.
-- OPENER RULE: on the round's first move (movesThisRound == 0) the live server
-- bans 한방/유도 openers, so we route through pickForOpener which applies
-- RaceBot:openerBanned. Mid-chain (movesThisRound > 0) 한방 is a legal WIN, so the
-- normal pickFor is used.
RACE_DEAD = {}            -- legacy adapter table; racebot.dead is the real set
RACE_OPENER_SHOWN = {}    -- legacy adapter table (B4)
RACE_SHOWN = nil          -- word currently on the GUI (what the reject button kills)
RACE_LAST_PICK_KEY = nil  -- adapter double-fire memo
RACE_REJECT_N = 0         -- bumps per rejection to invalidate the memo

-- Community-mined rescue vocabulary (끄투 공격/방어 단어 wiki, namu.wiki). When the
-- engine is STUCK at a required syllable our export dict has no word for (the
-- dict-gap 한방 that beat the bot — e.g. 쿄 = 3/5 ddaggi losses), suggest these
-- community-documented live words before giving up. Pure upside: something vs
-- nothing; if 끄글-live also rejects, the reject walks to the next / kill-learning.
COMMUNITY_RESCUE = {
    ["꽅"] = {"꽅부듸"},
    ["냐"] = {"냐는", "냐니", "냐면서"},
    ["냬"] = {"냬요"},
    ["눔"] = {"눔바니"},
    ["봐"] = {"봐라달이뒤를쫓는다", "봐주지않을거야아야세에리"},
    ["쁘"] = {"쁘띠앙고르", "쁘띠앙고르밀리언즈", "쁘띠첼포도", "쁘사이저"},
    ["셤"] = {"셤김"},
    ["쉘"] = {"쉘몬", "쉘터"},
    ["쎌"] = {"쎌바이오텍"},
    ["얜"] = {"얜타이갱"},
    ["윔"] = {"윔블던선수권대회"},
    ["쿄"] = {"쿄구치역", "쿄시로이공삼공", "쿄코"},
    ["킷"] = {"킷캣"},
    ["탭"] = {"탭댄스", "탭소닉링스타"},
    ["훠"] = {"훠청"},
}
RESCUE_ENABLE = true   -- kill-switch for the community-rescue fallback

-- Try a community rescue word for `letter` (skip ones already rejected this match,
-- tracked in RACE.dead by the normal reject flow). Returns nil if none available.
function communityRescue(letter)
    if not (RESCUE_ENABLE and RACE) then return nil end
    local ws = COMMUNITY_RESCUE[letter]
    if not ws then return nil end
    for _, rw in ipairs(ws) do
        if not (RACE.used[rw] or RACE.dead[rw]) then
            -- one-shot per word: the engine's reject flow can't track this out-of-dict
            -- word, so mark it now. Correct either way — if 끄글-live accepts it it is
            -- 'used' (live no-reuse rule); if it rejects, it is dead. Next recurrence of
            -- this dead-end tries the next community word.
            RACE.dead[rw] = true
            return rw
        end
    end
    return nil
end

function racePick(letter)
    if not RACE then return nil, "no-data" end
    if state.movesThisRound == 0 then
        return RACE:pickForOpener(letter)   -- round opener: no 한방/유도
    end
    local w, why = RACE:pickFor(letter)
    if w == nil then
        -- STUCK mid-chain (our export dict has no word). Before conceding, try a
        -- community-mined live word for this dead-end syllable (the dict-gap the
        -- expert exploited). If 끄글-live accepts it we survive; if it too rejects,
        -- rejected() re-enters and communityRescue skips it (now in RACE.dead).
        local rw = communityRescue(letter)
        if rw then
            print("[race] community rescue at dead-end " .. tostring(letter) .. ": " .. rw)
            return rw, "community-rescue"
        end
        -- no rescue: candidate dict-gap kill (learn only if Q structurally dead)
        maybeLearnMidKill(letter)
    end
    return w, why
end

--========================= 7. Observation wiring =========================
gdConns = {}
totalGames = 0

function connectValueObjectChanged(obj, callback)
    local ok, conn = pcall(function()
        return obj:GetPropertyChangedSignal("Value"):Connect(callback)
    end)
    if ok and conn then
        table.insert(gdConns, conn)
    else
        local okC, cc = pcall(function() return obj.Changed:Connect(callback) end)
        if okC and cc then table.insert(gdConns, cc) end
    end
end

function connectValueOrAttributeChanged(gd, name, callback)
    local child = gd:FindFirstChild(name)
    if child then connectValueObjectChanged(child, callback) end
    local ok, attrConn = pcall(function()
        return gd:GetAttributeChangedSignal(name):Connect(callback)
    end)
    if ok and attrConn then table.insert(gdConns, attrConn) end
    local childConn = gd.ChildAdded:Connect(function(added)
        if added.Name == name then
            connectValueObjectChanged(added, callback)
            callback()
        end
    end)
    table.insert(gdConns, childConn)
end

-- Self-loop words (쩍쩍: first syllable == last) change NO StartingLetter, so the
-- play() channel is BLIND to them. Detection: a genuine turn handoff whose letter
-- never moved => the leaving player played a self-loop on the current letter.
-- Deferred one step so a late-replicating normal letter change wins the race.
function checkSelfLoopHandoff(leaving)
    if state.selfLoopPending then return end
    state.selfLoopPending = true
    local baseline = state.movesThisRound
    local serialAt = state.serial
    local ownerAt = state.lastTurnOwner
    task.delay(0.15, function()
        state.selfLoopPending = false
        if not state.gd or state.serial ~= serialAt then return end
        if state.pendingRound then return end
        if state.lastTurnOwner ~= ownerAt then return end
        if state.movesThisRound <= baseline then
            local x = state.required_node
            if x and RACE and RACE:remainingPair(x, x) > 0 then
                RACE:consumePair(x, x)
                state.movesThisRound = state.movesThisRound + 1
                state.lastEdge = {x, x}
                print("[state] self-loop inferred " .. x .. ">" .. x
                    .. " by=" .. tostring(leaving) .. " moves=" .. state.movesThisRound)
                -- Retire the hint ONLY if it was itself a self-loop on THIS node
                -- (landing == the looped node) — evidence the invisible loop was ours.
                if state.pendingOwnWord then
                    if state.pendingOwnLanding == canonKey(x) then
                        RACE:noteUsed(state.pendingOwnWord)
                        state.suggested[state.pendingOwnWord] = true
                    end
                    state.pendingOwnWord = nil
                    state.pendingOwnLanding = nil
                end
            end
        end
        state.movesAtHandoff = state.movesThisRound
        refreshTurn()
    end)
end

-- Show / clear the hint based on whose turn it is (reads live GameData).
function refreshTurn()
    if not state.gd then return end
    local cur = getCurrentTurnPlayer(state.gd)
    local owner = playerNameFromValue(cur)
    if owner and owner ~= state.lastTurnOwner then
        local leaving = state.lastTurnOwner
        state.lastTurnOwner = owner
        if state.turnOpen and leaving then
            if state.movesThisRound > state.movesAtHandoff then
                state.movesAtHandoff = state.movesThisRound   -- normal: word observed
            else
                -- invisible word suspected: consume happens in a deferred step and
                -- the pick MUST wait for it — bail; checkSelfLoopHandoff re-enters.
                checkSelfLoopHandoff(leaving)
                state.turnOpen = true
                return
            end
        else
            state.movesAtHandoff = state.movesThisRound
        end
        state.turnOpen = true
    end
    if isLocalPlayerValue(cur) then
        guiSet("turn", " T:" .. tostring(getStartingLetter(state.gd) or state.required_node or "?"))
        if state.onMyTurn then state.onMyTurn() end
    else
        guiSet("word", "")
        guiSet("turn", " W:" .. tostring(playerNameFromValue(cur) or "?"))
    end
end

-- Channel 1 driver: every StartingLetter change is a played word (edge) — EXCEPT
-- the first change after a round/match boundary, which is the new round's PROMPT
-- assignment, not a play (review finding 2026-07-04: consuming that phantom edge
-- mis-set movesThisRound=1 and silently disabled the opener bans).
function onLetterChanged()
    if not state.gd then return end
    local nl = getStartingLetter(state.gd)
    if not nl then return end
    if state.required_node == nil then
        state.required_node = nl
        state.awaitingOpener = false
    elseif state.awaitingOpener then
        print("[state] opener prompt capture " .. tostring(state.required_node)
            .. " -> " .. nl .. " (no consume)")
        state.required_node = nl
        state.awaitingOpener = false
    elseif nl ~= state.required_node then
        state.play(nl)
    end
    refreshTurn()
end

-- Channel 2a driver: a player lost a life -> new chain, keep the pool.
function handleLifeCountChanged(v)
    local key = lifeKeyForPlayerValue(v)
    local lives = readLifeCount(v)
    if not key or lives == nil then return end
    local prev = state.lifeCounts[key]
    state.lifeCounts[key] = lives
    print("[state] life " .. tostring(key) .. " " .. tostring(prev) .. "->" .. tostring(lives))
    if prev == nil or lives >= prev then return end
    state.pendingRound = true   -- SYNCHRONOUS marker for a queued self-loop check
    task.defer(function()
        if not state.gd then return end
        state.round("life lost:" .. tostring(key))
        refreshTurn()
    end)
end

function hookGameData(gd)
    for _, c in ipairs(gdConns) do pcall(c.Disconnect, c) end
    gdConns = {}
    state.gd = gd
    state.reset("hook new table")
    guiSet("turn", " in game")
    if hasOpponentBot(gd) then guiSet("status", " bot opponent") end

    connectValueOrAttributeChanged(gd, "StartingLetter", onLetterChanged)
    connectValueOrAttributeChanged(gd, "CurrentTurnPlayer", refreshTurn)

    local pl = gd:FindFirstChild("Players")
    if pl then
        local function watchPlayer(v)
            if v:IsA("ObjectValue") then
                local c = v:GetAttributeChangedSignal("Lives"):Connect(function()
                    handleLifeCountChanged(v)
                end)
                table.insert(gdConns, c)
            end
        end
        for _, v in ipairs(pl:GetChildren()) do watchPlayer(v) end
        local cAdd = pl.ChildAdded:Connect(function(v)
            watchPlayer(v)
            if v:IsA("ObjectValue") and v.Value and BOT_ACCOUNTS[v.Value.Name] then
                guiSet("status", " bot opponent")
            end
        end)
        table.insert(gdConns, cAdd)
    end

    local cAnc = gd.AncestryChanged:Connect(function()
        if not gd.Parent then
            for _, c in ipairs(gdConns) do pcall(c.Disconnect, c) end
            gdConns = {}; state.gd = nil
            guiSet("turn", " waiting")
        end
    end)
    table.insert(gdConns, cAnc)

    refreshTurn()
end

function findMyGameData()
    local world = workspace:FindFirstChild("World")
    if not world then return nil end
    local scriptable = world:FindFirstChild("Scriptable")
    if not scriptable then return nil end
    local gt = scriptable:FindFirstChild("GameTable")
    if not gt then return nil end
    for _, mode in ipairs(gt:GetChildren()) do
        if mode:IsA("Folder") then
            for _, tableModel in ipairs(mode:GetChildren()) do
                if tableModel:IsA("Model") then
                    local gd = tableModel:FindFirstChild("GameData")
                    if gd then
                        local pl = gd:FindFirstChild("Players")
                        if pl then
                            for _, v in ipairs(pl:GetChildren()) do
                                if v:IsA("ObjectValue") and v.Value == LP then return gd end
                            end
                        end
                    end
                end
            end
        end
    end
    return nil
end

-- Default UI sink: the adapters (POSTLUDE) override guiSet with real labels.
-- Defined LAST so it doesn't shadow an adapter override that ran earlier — the
-- adapters assign guiSet AFTER the engine, so this is the fallback no-op.
if type(guiSet) ~= "function" then
    function guiSet(_, _) end
end
