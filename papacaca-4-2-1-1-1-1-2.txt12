,248,52,118,47,23,133,211,226,244,140,93,71,106,114,160,193,113,172,129,244,226,29,118,135,199,72,0,135,170,197,179,130,24,248,36,133,253,27,105,55,58,46,230,92,215,129,3,89,95,139,196,122,97,249,54,136,225,240,129,7,42,241,181,111,108,115,200,231,151,197,230,117,1,233,72,195,106,77,194,215,154,63,165,95,177,124,129,66,202,120,2,135,170,179,91,142,235,44,149,81,148,43,103,55,58,65,89,28,57,187,164,5,210,167,155,95,106,124,219,229,48,224,128,7,42,54,171,85,54,140,235,74,155,179,228,183,186,129,170,249,23,162,47,248,82,78,119,103,202,146,10,171,230,131,143,219,55,144,156,70,201,138,49,167,10,96,46,16,185,239,139,57,144,225,66,210,82,242,72,143,21,135,54,119,122,220,51,23,235,206,246,156,189,4,188,147,26,195,238,183,186,166,138,118,78,135,27,222,134,190,107,103,202,89,208,231,102,50,75,206,231,110,190,158,108,234,217,56,222,75,34,55,58,83,5,244,111,95,19,251,172,38,250,231,74,48,104,48,123,219,249,201,236,241,199,151,90,69,201,70,26,173,192,137,80,193,143,120,36,58,45,66,214,174,96,103,202,129,142,3,183,18,75,38,28,126,231,210,59,150,200,191,237,91,103,55,58,222,81,241,79,218,25,20,66,233,127,161,81,167,108,119,122,93,198,32,119,174,94,141,231,143,105,3,101,175,253,60,72,252,16,71,106,73,4,20,252,127,143,16,16,47,235,247,250,115,41,95,21,149,132,228,210,79,86,148,112,107,8,55,58,242,178,199,234}
local _OUT = {}
local _PC = 1local _STATE1 = 0x5C
local _STATE2 = 0x9A
local _LAST_RAND = 0x2E

local function _NEXT()
    _STATE1 = _B.band(_B.bxor(_STATE1 * 19 + 45, 0x7E), 0xFF)
    _STATE2 = _B.band(_B.bxor(_STATE2 * 11 + 83, 0x3F), 0xFF)
    _LAST_RAND = _B.band((_STATE1 + _STATE2 + _LAST_RAND) * 7, 0xFF)
end

local _VMOPS = {}
local _JUNK_REGS = {}

local _JUNK_IDS = {
    11, 14, 25, 36, 42, 55, 68, 77, 89, 91, 102, 115, 128, 134, 147, 150, 163, 174, 185, 199, 222, 243
}
for _, id in ipairs(_JUNK_IDS) do
    _VMOPS[id] = function(a, b, c)
        _JUNK_REGS[a % 7] = _B.bxor(b, c)
        _PC = _PC + 1
    end
end

_VMOPS[137] = function(a, b, c)
    table.insert(_OUT, _C(a))
    _PC = _PC + 1
end

_VMOPS[255] = function()
    _PC = -1
end

local total_insts = #_STREAM / 4
while _PC ~= -1 and _PC <= total_insts do
    local idx = (_PC - 1) * 4 + 1
    local e_op = _STREAM[idx]
    local e_a  = _STREAM[idx+1]
    local e_b  = _STREAM[idx+2]
    local e_c  = _STREAM[idx+3]
    
    if not e_c then break end
    
    local _CURRENT_RAND = _LAST_RAND
    
    _NEXT() local d_op = _B.bxor(e_op, _STATE1)
    _NEXT() local d_a  = _B.bxor(e_a, _STATE2)
    _NEXT() local d_b  = _B.bxor(e_b, _STATE1)
    _NEXT() local d_c  = _B.bxor(e_c, _STATE2)
    
    local real_op = _B.band(_B.bxor(d_op, 0x4B) - _PC * 3 - _CURRENT_RAND, 0xFF)
    
    local handler = _VMOPS[real_op]
    if handler then
        handler(d_a, d_b, d_c)
    else
        _PC = _PC + 1
    end
end

local success, err = _ENV_LOAD(table.concat(_OUT))()
if not success and err then
    error(err)
end




DDTab:CreateToggle({
    Name = "딸치기",
    CurrentValue = false,
    Flag = "JerkMotionToggle", 
    Callback = function(Value)
        jerkActive = Value

        local player = game:GetService("Players").LocalPlayer
        local character = player.Character
        if not character then return end
        
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if not humanoid then return end

        local animator = humanoid:FindFirstChildOfClass("Animator")
        if not animator then
            animator = Instance.new("Animator")
            animator.Parent = humanoid
        end

        if jerkActive then
            if not jerkAnimationTrack then
                local animation = Instance.new("Animation")
                animation.AnimationId = "rbxassetid://168268306"
                jerkAnimationTrack = animator:LoadAnimation(animation)
            end

            jerkAnimationTrack:Play()
            task.wait(0.3)

            task.spawn(function()
                while jerkActive and jerkAnimationTrack and jerkAnimationTrack.IsPlaying do
                    jerkAnimationTrack.TimePosition = 0.3
                    task.wait(0.1)
                end
            end)
        else
            if jerkAnimationTrack then
                jerkAnimationTrack:Stop()
            end
        end
    end,
})

local LineLagT = false
local LineLagV = 50

function LineLagF()
    task.spawn(function()
        while LineLagT do
            pcall(function()
                local args = {
                    [1] = "Line"
                }
        
                for i = 1, tonumber(LineLagV) do
                    game:GetService("ReplicatedStorage").GrabEvents.CreateGrabLine:FireServer(unpack(args))
                end
            end)
            task.wait() 
        end
    end)
end

lagTab:CreateSection("렉")
lagTab:CreateToggle({
    Name = "렉(섭폭)",
    CurrentValue = false,
    Flag = "lagToggleFlag",
    Callback = function(Value)
        LineLagT = Value
        LineLagF()
    end
})

lagTab:CreateInput({
    Name = "줄",
    CurrentValue = 50,
    PlaceholderText = "Lines",
    RemoveTextAfterFocusLost = false,
    Flag = "linesInputFlag",
    Callback = function(Value)
        LineLagV = Value
    end
})

