local SpectateToggle = ListTab:CreateToggle({
    Name = "관전 기능 활성화",
    CurrentValue = false,
    Flag = "SpectateToggleFlag",
    Callback = function(Value)
        if Value then
            if teleportGui then teleportGui:Destroy() end
            if camConnection then camConnection:Disconnect() camConnection = nil end

            teleportGui = Instance.new("ScreenGui")
            teleportGui.Name = "IndependentSpectateGui"
            teleportGui.ResetOnSpawn = false

            local success, err = pcall(function()
                teleportGui.Parent = game:GetService("CoreGui")
            end)
            if not success then
                teleportGui.Parent = plr.PlayerGui
            end

            local mainFrame = Instance.new("Frame")
            mainFrame.Name = "MainFrame"
            mainFrame.Size = UDim2.new(0, 180, 0, 240)
            mainFrame.Position = UDim2.new(0, 10, 0.5, -120)
            mainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
            mainFrame.BorderSizePixel = 0
            mainFrame.Active = true
            mainFrame.Parent = teleportGui

            local uiCorner = Instance.new("UICorner")
            uiCorner.CornerRadius = UDim.new(0, 8)
            uiCorner.Parent = mainFrame

            local userInputService = game:GetService("UserInputService")
            local dragging, dragInput, dragStart, startPos

            mainFrame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    dragStart = input.Position
                    startPos = mainFrame.Position

                    input.Changed:Connect(function()
                        if input.UserInputState == Enum.UserInputState.End then
                            dragging = false
                        end
                    end)
                end
            end)

            mainFrame.InputChanged:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                    dragInput = input
                end
            end)

            userInputService.InputChanged:Connect(function(input)
                if input == dragInput and dragging then
                    local delta = input.Position - dragStart
                    mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
                end
            end)

            local scrollingFrame = Instance.new("ScrollingFrame")
            scrollingFrame.Name = "List"
            scrollingFrame.Size = UDim2.new(1, -10, 1, -10)
            scrollingFrame.Position = UDim2.new(0, 5, 0, 5)
            scrollingFrame.BackgroundTransparency = 1
            scrollingFrame.BorderSizePixel = 0
            scrollingFrame.ScrollBarThickness = 2
            scrollingFrame.ScrollBarImageColor3 = Color3.fromRGB(80, 80, 80)
            scrollingFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
            scrollingFrame.Parent = mainFrame

            local uiListLayout = Instance.new("UIListLayout")
            uiListLayout.Padding = UDim.new(0, 6)
            uiListLayout.SortOrder = Enum.SortOrder.LayoutOrder
            uiListLayout.Parent = scrollingFrame

            uiListLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                scrollingFrame.CanvasSize = UDim2.new(0, 0, 0, uiListLayout.AbsoluteContentSize.Y)
            end)

            local function updateList()
                for _, child in ipairs(scrollingFrame:GetChildren()) do
                    if child:IsA("Frame") then child:Destroy() end
                end

                for _, p in ipairs(game:GetService("Players"):GetPlayers()) do
                    if p ~= plr then
                        local itemFrame = Instance.new("Frame")
                        itemFrame.Name = p.Name
                        itemFrame.Size = UDim2.new(1, -4, 0, 50)
                        itemFrame.BackgroundColor3 = Color3.fromRGB(24, 24, 24)
                        itemFrame.BorderSizePixel = 0
                        itemFrame.ClipsDescendants = true
                        itemFrame.Parent = scrollingFrame

                        local itemCorner = Instance.new("UICorner")
                        itemCorner.CornerRadius = UDim.new(0, 6)
                        itemCorner.Parent = itemFrame

                        local pImage = Instance.new("ImageLabel")
                        pImage.Name = "Avatar"
                        pImage.Size = UDim2.new(0, 40, 0, 40)
                        pImage.Position = UDim2.new(0, 5, 0, 5)
                        pImage.BackgroundTransparency = 1
                        
                        task.spawn(function()
                            local s, content = pcall(function()
                                return game:GetService("Players"):GetUserThumbnailAsync(p.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
                            end)
                            if s then pImage.Image = content end
                        end)
                        pImage.Parent = itemFrame

                        local imgCorner = Instance.new("UICorner")
                        imgCorner.CornerRadius = UDim.new(1, 0)
                        imgCorner.Parent = pImage

                        local pName = Instance.new("TextLabel")
                        pName.Name = "Name"
                        pName.Size = UDim2.new(1, -55, 1, 0)
                        pName.Position = UDim2.new(0, 50, 0, 0)
                        pName.BackgroundTransparency = 1
                        pName.Text = p.DisplayName .. "\n" .. "@" .. p.Name
                        pName.TextColor3 = Color3.fromRGB(255, 255, 255)
                        pName.TextSize = 11
                        pName.TextXAlignment = Enum.TextXAlignment.Left
                        pName.Font = Enum.Font.SourceSansBold
                        pName.Parent = itemFrame

                        local buttonContainer = Instance.new("Frame")
                        buttonContainer.Name = "Buttons"
                        buttonContainer.Size = UDim2.new(1, 0, 1, 0)
                        buttonContainer.Position = UDim2.new(1, 0, 0, 0)
                        buttonContainer.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
                        buttonContainer.BorderSizePixel = 0
                        buttonContainer.Parent = itemFrame

                        local containerCorner = Instance.new("UICorner")
                        containerCorner.CornerRadius = UDim.new(0, 6)
                        containerCorner.Parent = buttonContainer

                        local specBtn = Instance.new("TextButton")
                        specBtn.Name = "Spec"
                        specBtn.Size = UDim2.new(0, 50, 0, 30)
                        specBtn.Position = UDim2.new(0, 10, 0.5, -15)
                        specBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
                        specBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                        specBtn.Text = "관전"
                        specBtn.TextSize = 11
                        specBtn.Font = Enum.Font.SourceSansBold
                        specBtn.Parent = buttonContainer

                        local btnCorner1 = Instance.new("UICorner")
                        btnCorner1.CornerRadius = UDim.new(0, 4)
                        btnCorner1.Parent = specBtn

                        local tpBtn = Instance.new("TextButton")
                        tpBtn.Name = "Tp"
                        tpBtn.Size = UDim2.new(0, 50, 0, 30)
                        tpBtn.Position = UDim2.new(0, 65, 0.5, -15)
                        tpBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 80)
                        tpBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                        tpBtn.Text = "텔포"
                        tpBtn.TextSize = 11
                        tpBtn.Font = Enum.Font.SourceSansBold
                        tpBtn.Parent = buttonContainer

                        local btnCorner2 = Instance.new("UICorner")
                        btnCorner2.CornerRadius = UDim.new(0, 4)
                        btnCorner2.Parent = tpBtn

                        local backBtn = Instance.new("TextButton")
                        backBtn.Name = "Back"
                        backBtn.Size = UDim2.new(0, 30, 0, 30)
                        backBtn.Position = UDim2.new(1, -40, 0.5, -15)
                        backBtn.BackgroundTransparency = 1
                        backBtn.Text = "X"
                        backBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
                        backBtn.TextSize = 12
                        backBtn.Font = Enum.Font.SourceSansBold
                        backBtn.Parent = buttonContainer

                        local clickTrigger = Instance.new("TextButton")
                        clickTrigger.Name = "Trigger"
                        clickTrigger.Size = UDim2.new(1, 0, 1, 0)
                        clickTrigger.BackgroundTransparency = 1
                        clickTrigger.Text = ""
                        clickTrigger.ZIndex = 2
                        clickTrigger.Parent = itemFrame

                        local isTweening = false

                        clickTrigger.MouseButton1Click:Connect(function()
                            if isTweening then return end
                            isTweening = true
                            clickTrigger.Visible = false
                            buttonContainer:TweenPosition(UDim2.new(0, 0, 0, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.2, true, function()
                                isTweening = false
                            end)
                        end)

                        backBtn.MouseButton1Click:Connect(function()
                            if isTweening then return end
                            isTweening = true
                            buttonContainer:TweenPosition(UDim2.new(1, 0, 0, 0), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.2, true, function()
                                clickTrigger.Visible = true
                                isTweening = false
                            end)
                        end)

                        specBtn.MouseButton1Click:Connect(function()
                            if camConnection then camConnection:Disconnect() end
                            
                            if specBtn.Text == "관전" then
                                for _, frame in ipairs(scrollingFrame:GetChildren()) do
                                    if frame:IsA("Frame") and frame:FindFirstChild("Buttons") then
                                        local sBtn = frame.Buttons:FindFirstChild("Spec")
                                        if sBtn then
                                            sBtn.Text = "관전"
                                            sBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
                                        end
                                    end
                                end
                                
                                specBtn.Text = "해제"
                                specBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
                                
                                camConnection = rs2.RenderStepped:Connect(function()
                                    if p and p.Character and p.Character:FindFirstChild("Humanoid") then
                                        workspace.CurrentCamera.CameraSubject = p.Character.Humanoid
                                    else
                                        if plr.Character and plr.Character:FindFirstChild("Humanoid") then
                                            workspace.CurrentCamera.CameraSubject = plr.Character.Humanoid
                                        end
                                    end
                                end)
                            else
                                specBtn.Text = "관전"
                                specBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
                                if plr.Character and plr.Character:FindFirstChild("Humanoid") then
                                    workspace.CurrentCamera.CameraSubject = plr.Character.Humanoid
                                end
                            end
                        end)

                        tpBtn.MouseButton1Click:Connect(function()
                            if p and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                                local myChar = plr.Character
                                if myChar and myChar:FindFirstChild("HumanoidRootPart") then
                                    myChar.HumanoidRootPart.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0, 2, 0)
                                end
                            end
                        end)
                    end
                end
            end

            updateList()
            
            local addConn = game:GetService("Players").PlayerAdded:Connect(updateList)
            local rmConn = game:GetService("Players").PlayerRemoving:Connect(updateList)
            
            mainFrame.Destroying:Connect(function()
                addConn:Disconnect()
                rmConn:Disconnect()
            end)
        else
            if camConnection then
                camConnection:Disconnect()
                camConnection = nil
            end
            if plr.Character and plr.Character:FindFirstChild("Humanoid") then
                workspace.CurrentCamera.CameraSubject = plr.Character.Humanoid
            end
            if teleportGui then
                teleportGui:Destroy()
                teleportGui = nil
            end
        end
    end,
})
